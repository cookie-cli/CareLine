API_VERSION=v1
GROQ_API_KEY=your_groq_api_key_here
FIREBASE_KEY_PATH=backend/.secrets/firebase-key.json
ALLOW_MISSING_FIREBASE=false
AUTH_REQUIRED=true
AUTH_DEBUG=false
FIREBASE_CHECK_REVOKED=false
FIREBASE_CLOCK_SKEW_SECONDS=60
LINK_CODE_LENGTH=8
LINK_CODE_MAX_ATTEMPTS=8
LINK_QR_BASE_URL=https://careline.app/link
LINK_CODE_PEPPER=change_me_for_production
ALLOWED_ORIGINS=https://your-frontend-domain.com,https://staging-your-frontend-domain.com
MAX_UPLOAD_SIZE_MB=10
RATE_LIMIT_PER_MINUTE=30
OUTBOUND_TIMEOUT_SECONDS=30

# Optional: bot auto-auth variables for tests/scripts/api_security_bot.py
FIREBASE_WEB_API_KEY=your_firebase_web_api_key
TEST_EMAIL=your_test_user_email
TEST_PASSWORD=your_test_user_password
